# Banco — connection string PostgreSQL (Neon/Railway)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Auth — chave de assinatura JWT (gere com: python -c "import secrets;print(secrets.token_urlsafe(48))")
# Mínimo de 32 caracteres. O backend recusa boot se ausente ou curta.
SECRET_KEY=

# CORS — origens permitidas (CSV)
ALLOWED_ORIGINS=https://imile-react.vercel.app,http://localhost:5173,http://localhost:5174

# E-mail (Brevo) — opcional; convites por e-mail só funcionam se setado
BREVO_API_KEY=
BREVO_FROM_EMAIL=noreply@imile.me
BREVO_FROM_NAME=iMile Dashboard
APP_URL=https://imile-react.vercel.app

# Notificações Lark/Feishu — opcional
LARK_WEBHOOK_URL=

# WhatsApp Cloud API — opcional
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=

# JWT TTLs (opcional — defaults: 60 min / 30 dias)
ACCESS_TOKEN_MINUTES=60
REFRESH_TOKEN_DAYS=30
